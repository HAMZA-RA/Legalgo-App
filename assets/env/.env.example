# Copy to assets/env/.env for local tooling if desired.
# Runtime config is read from dart-define in production builds.
LEGALGO_ENV=development

# Optional full override. Highest priority on every platform.
# LEGALGO_API_BASE_URL=http://localhost:3001/api/v1

# Platform defaults when LEGALGO_API_BASE_URL and LEGALGO_API_HOST are omitted:
# - Flutter Web: http://localhost:3001/api/v1
# - Android emulator: http://10.0.2.2:3001/api/v1
# - Other desktop/simulator targets: http://localhost:3001/api/v1

# Physical devices cannot reach your computer via localhost.
# Set this to your machine LAN IP, for example 192.168.1.20.
# LEGALGO_API_HOST=192.168.1.20
LEGALGO_API_SCHEME=http
LEGALGO_API_PORT=3001

LEGALGO_WEB_SUCCESS_URL=legalgo://payment/success
LEGALGO_WEB_CANCEL_URL=legalgo://payment/cancel
